{
  "compilerOptions": {
    "allowJs": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "lib": ["ES2021", "DOM"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "noImplicitAny": true,
    "paths": {
      "@/*": ["../src/*"]
    },
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2021"
  },
  "include": ["./**/*"],
  "exclude": ["./_generated"]
}
