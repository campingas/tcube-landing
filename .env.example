# Public browser value. Safe to expose.
# Local value is generated by `pnpm convex:dev`.
VITE_CONVEX_URL=

# Secret. Use only locally if deploying Convex from your machine.
# In production, set this in Vercel Project Settings.
CONVEX_DEPLOY_KEY=

# Optional only if later switching to Vercel CLI deployment from GitHub Actions.
# Not needed for the recommended Vercel Git integration.
VERCEL_ORG_ID=
VERCEL_PROJECT_ID=
VERCEL_TOKEN=
