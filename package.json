{
  "name": "tcube-landing",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "format": "prettier --write src index.html *.config.* package.json",
    "format:check": "prettier --check src index.html *.config.* package.json",
    "lint": "eslint src --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "verify": "pnpm format:check && pnpm typecheck && pnpm lint"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^26.0.1",
    "@types/three": "^0.185.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^9.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.4.2",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.20.0",
    "vite": "^5.4.11"
  },
  "dependencies": {
    "three": "^0.185.0"
  }
}
